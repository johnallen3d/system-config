{
  "$schema": "https://opencode.ai/config.json",
  "theme": "tokyonight",
  "model": "github-copilot/claude-sonnet-4-5",
  "autoupdate": true,
  "keybinds": {
    "leader": "ctrl+l"
  },
  "agent": {
    "beast": {
      "mode": "primary",
      "model": "github-copilot/gpt-5-mini",
      "prompt": "{file:./prompts/beast-mode.txt}"
    }
  },
  "skills": {
    "paths": ["~/dev/src/amfaro/skills"]
  },
  "plugin": ["./plugin/ai-intercept.js", "context-mode"],
  "mcp": {
    "context-mode": {
      "type": "local",
      "command": ["context-mode"]
    },
    "mcp-server-doppler": {
      "type": "local",
      "command": [
        "bash",
        "-lc",
        "export DOPPLER_TOKEN=\"$(security find-generic-password -s 'doppler-work' -a 'john.allen' -w)\" && exec npx -y @dopplerhq/mcp-server"
      ],
      "enabled": true
    },
    "mcp-server-motherduck": {
      "type": "local",
      "command": ["uvx", "mcp-server-motherduck", "--db-path", ":memory:"],
      "enabled": true
    }
  },
  "provider": {
    "ollama": {
      "models": {
        "qwen2.5-coder:14b": {
          "_launch": true,
          "name": "qwen2.5-coder:14b"
        }
      },
      "name": "Ollama (local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  },
  "formatter": {
    "biome": {
      "command": ["biome", "format", "--write", "$FILE"],
      "extensions": [".js", ".jsx", ".ts", ".tsx"]
    },
    "stylua": {
      "command": ["stylua", "$FILE"],
      "extensions": [".lua"]
    },
    "yamlfmt": {
      "command": ["yamlfmt", "$FILE"],
      "extensions": [".yaml", ".yml"]
    },
    "rustfmt": {
      "command": ["rustfmt", "$FILE"],
      "extensions": [".rs"]
    }
  }
}
