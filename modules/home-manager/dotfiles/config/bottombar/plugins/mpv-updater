#!/usr/bin/env bash

# mpv-queue bottombar updater
# Polls `mpv-queue --backend voxio --json now` for current playback info.

set -u

# Ensure PATH includes nix-installed binaries
export PATH="/etc/profiles/per-user/$USER/bin:/run/current-system/sw/bin:$HOME/bin:$PATH"

MPV_QUEUE=(mpv-queue --backend voxio --json now)
COVER_ART_THUMB="/tmp/mpv-cover.png"
last_cover_src=""

hide_music() {
    bottombar -m --set music drawing=off --set music_art drawing=off --set music_repeat drawing=off --set music_shuffle drawing=off
}

format_time() {
    local secs="$1"
    if [[ -n "$secs" && "$secs" != "null" ]]; then
        local whole=${secs%.*}
        printf "%d:%02d" $((whole / 60)) $((whole % 60))
    fi
}

while true; do
    status_json=$("${MPV_QUEUE[@]}" 2>/dev/null || true)

    if [[ -z "$status_json" ]]; then
        hide_music
        sleep 2
        continue
    fi

    state=$(printf '%s\n' "$status_json" | jq -r '.state // "stopped"')
    if [[ "$state" == "stopped" ]]; then
        hide_music
        sleep 2
        continue
    fi

    paused=$(printf '%s\n' "$status_json" | jq -r '.paused // false')
    if [[ "$paused" == "true" ]]; then
        icon=$'\uf04b' # play icon while paused
    else
        icon=$'\uf04c' # pause icon while playing
    fi

    label=$(printf '%s\n' "$status_json" | jq -r '[.current_track.title, .current_track.artist, .current_track.album] | map(select(. != null and . != "")) | join(" • ")')

    elapsed=$(printf '%s\n' "$status_json" | jq -r '.elapsed_secs // empty')
    duration=$(printf '%s\n' "$status_json" | jq -r '.duration_secs // empty')
    if [[ -n "$elapsed" && -n "$duration" ]]; then
        elapsed_fmt=$(format_time "$elapsed")
        duration_fmt=$(format_time "$duration")
        if [[ -n "$elapsed_fmt" && -n "$duration_fmt" ]]; then
            label="$label [$elapsed_fmt/$duration_fmt]"
        fi
    fi

    cover_art_path=$(printf '%s\n' "$status_json" | jq -r '.cover_art_path // empty')
    repeat=$(printf '%s\n' "$status_json" | jq -r '.repeat // false')
    shuffle=$(printf '%s\n' "$status_json" | jq -r '.shuffle // false')

    bottombar -m --set music icon="$icon" icon.drawing=on icon.font="Font Awesome 6 Pro:Regular:14.0" label="$label" drawing=on

    if [[ -n "$cover_art_path" && -f "$cover_art_path" ]]; then
        if [[ "$cover_art_path" != "$last_cover_src" ]]; then
            if sips -s format png -Z 128 "$cover_art_path" --out "$COVER_ART_THUMB" >/dev/null 2>&1; then
                last_cover_src="$cover_art_path"
            fi
        fi
        bottombar -m --set music_art background.image="$COVER_ART_THUMB" drawing=on
    else
        bottombar -m --set music_art drawing=off
    fi

    if [[ "$repeat" == "true" ]]; then
        bottombar -m --set music_repeat icon.drawing=on drawing=on
    else
        bottombar -m --set music_repeat drawing=off
    fi

    if [[ "$shuffle" == "true" ]]; then
        bottombar -m --set music_shuffle icon.drawing=on drawing=on
    else
        bottombar -m --set music_shuffle drawing=off
    fi

    sleep 0.5
done
