#!/usr/bin/env bash
#MISE description="Summarize Pi parent/subagent model usage from session logs"
#USAGE flag "--aggregate" help="Collapse recent sessions into model totals only"
#USAGE flag "--sum" help="Alias for --aggregate"
#USAGE flag "--totals-only" help="Alias for --aggregate"
#USAGE flag "--json" help="Emit JSON"
#USAGE flag "--csv" help="Emit CSV"
#USAGE arg "[target]" help="latest | current | recent[:N] | <session-id> | <session-path> (profile-scoped by default)"
#USAGE arg "[count]" help="Recent count when target is 'recent'"
set -euo pipefail

exec pi-model-usage "$@"
