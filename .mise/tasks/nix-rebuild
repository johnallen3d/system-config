#!/usr/bin/env bash
#MISE description="Apply darwin-rebuild (updates flake by default); logs to temp file"
#USAGE flag "--switch-only" help="Skip nix flake update"
set -uo pipefail

raise_nofile_limit() {
  local hard_limit
  hard_limit="$(ulimit -Hn)"
  ulimit -Sn "$hard_limit"
}

restart_service() {
  local service="$1"
  launchctl kickstart -k "gui/$(id -u)/org.nixos.${service}"
}

log="$(mktemp -t nix-rebuild.XXXXXX.log)"
printf 'nix-rebuild log: %s\n' "$log" >&2

{
  # macOS launchd can leave GUI shells at maxfiles soft=256.
  # Raise to hard limit so flake input fetches do not hit tarball-cache EMFILE.
  raise_nofile_limit

  if [[ "${usage_switch_only:-}" != "true" ]]; then
    nix flake update
  fi
  sudo darwin-rebuild switch --impure --flake "$HOME/dev/src/system-config/"
} >"$log" 2>&1
rc=$?

if [[ "$rc" -eq 0 ]]; then
  restart_service borders
fi

printf 'nix-rebuild log: %s (exit %d)\n' "$log" "$rc" >&2
exit "$rc"
