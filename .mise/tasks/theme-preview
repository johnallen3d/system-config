#!/usr/bin/env bash
#MISE description="Preview Tokyo Night palette swatches from repo theme files"
#USAGE flag "--detailed" help="Show grouped metadata and token names"
#USAGE flag "--all" help="Show every token instead of grouped unique colors"
set -euo pipefail

python3 - "$@" <<'PY'
from __future__ import annotations

import colorsys
import re
import sys
import xml.etree.ElementTree as ET
from collections import OrderedDict, defaultdict
from pathlib import Path

ROOT = Path.cwd()
SHOW_DETAILED = "--detailed" in sys.argv[1:]
SHOW_ALL = "--all" in sys.argv[1:]


def rgb_from_aarrggbb(raw: str) -> tuple[str, str]:
    raw = raw.upper()
    return f"#{raw[2:]}", raw[:2]


def rgb_from_rrggbbaa(raw: str) -> tuple[str, str]:
    raw = raw.upper()
    if len(raw) == 6:
        return f"#{raw}", "FF"
    return f"#{raw[:6]}", raw[6:]


def swatch(rgb: str, alpha: str) -> str:
    if alpha == "00":
        return "(transparent)"
    r = int(rgb[1:3], 16)
    g = int(rgb[3:5], 16)
    b = int(rgb[5:7], 16)
    return f"\033[48;2;{r};{g};{b}m        \033[0m"


def family_and_sort_key(rgb: str) -> tuple[str, tuple[int, float, float, float]]:
    r = int(rgb[1:3], 16)
    g = int(rgb[3:5], 16)
    b = int(rgb[5:7], 16)
    rf, gf, bf = r / 255.0, g / 255.0, b / 255.0
    h, s, v = colorsys.rgb_to_hsv(rf, gf, bf)
    maxc = max(rf, gf, bf)
    minc = min(rf, gf, bf)
    luma = 0.2126 * rf + 0.7152 * gf + 0.0722 * bf
    spread = maxc - minc

    if spread < 0.08 or s < 0.18:
        if luma < 0.20:
            return "black", (0, luma, h, v)
        if luma < 0.72:
            return "gray", (1, luma, h, v)
        return "white", (2, luma, h, v)

    deg = h * 360.0
    if deg < 12 or deg >= 345:
        return "red", (3, deg, -luma, -v)
    if deg < 45:
        return "orange", (4, deg, -luma, -v)
    if deg < 70:
        return "yellow", (5, deg, -luma, -v)
    if deg < 160:
        return "green", (6, deg, -luma, -v)
    if deg < 195:
        return "cyan", (7, deg, -luma, -v)
    if deg < 255:
        return "blue", (8, deg, -luma, -v)
    if deg < 290:
        return "purple", (9, deg, -luma, -v)
    if deg < 345:
        return "pink", (10, deg, -luma, -v)
    return "other", (11, deg, -luma, -v)


def token_preview(tokens: list[str], limit: int = 4) -> str:
    if len(tokens) <= limit:
        return ", ".join(tokens)
    return f"{', '.join(tokens[:limit])} (+{len(tokens) - limit})"


def preferred_entry(entries: list[dict[str, str]]) -> dict[str, str]:
    return sorted(entries, key=lambda entry: (entry["alpha"] != "FF", entry["alpha"] == "00"))[0]


def parse_lua_aarrggbb(path: Path) -> list[dict[str, str]]:
    entries = []
    pattern = re.compile(r"^\s*([A-Za-z_][A-Za-z0-9_]*)\s*=\s*0x([0-9A-Fa-f]{8})\s*,?")
    for line in path.read_text().splitlines():
        match = pattern.match(line)
        if not match:
            continue
        token, raw = match.groups()
        rgb, alpha = rgb_from_aarrggbb(raw)
        entries.append({"token": token, "rgb": rgb, "alpha": alpha, "raw": f"0x{raw.upper()}"})
    return entries


def parse_shell_aarrggbb(path: Path) -> list[dict[str, str]]:
    entries = []
    pattern = re.compile(r'^\s*([A-Za-z_][A-Za-z0-9_]*)="(0x[0-9A-Fa-f]{8}|#[0-9A-Fa-f]{6})"')
    for line in path.read_text().splitlines():
        match = pattern.match(line)
        if not match:
            continue
        token, raw = match.groups()
        if raw.startswith("0x"):
            rgb, alpha = rgb_from_aarrggbb(raw[2:])
        else:
            rgb, alpha = rgb_from_rrggbbaa(raw[1:])
        entries.append({"token": token, "rgb": rgb, "alpha": alpha, "raw": raw.upper()})
    return entries


def parse_fish(path: Path) -> list[dict[str, str]]:
    entries = []
    bare_pattern = re.compile(r"^\s*([A-Za-z_][A-Za-z0-9_]*)\s+([0-9A-Fa-f]{6})\s*$")
    bg_pattern = re.compile(r"^\s*([A-Za-z_][A-Za-z0-9_]*)\s+--background=([0-9A-Fa-f]{6})\s*$")
    for line in path.read_text().splitlines():
        match = bare_pattern.match(line)
        kind = "foreground"
        if not match:
            match = bg_pattern.match(line)
            kind = "background"
        if not match:
            continue
        token, raw = match.groups()
        rgb, alpha = rgb_from_rrggbbaa(raw)
        entries.append({"token": f"{token}.{kind}", "rgb": rgb, "alpha": alpha, "raw": f"#{raw.upper()}"})
    return entries


def parse_tmtheme(path: Path) -> list[dict[str, str]]:
    entries = []
    text = path.read_text()
    text = re.sub(r"<!DOCTYPE[^>]*>", "", text, count=1)
    root = ET.fromstring(text)

    def decode(elem):
        tag = elem.tag
        if tag == "dict":
            out = {}
            children = list(elem)
            i = 0
            while i < len(children):
                key_elem = children[i]
                if key_elem.tag != "key":
                    i += 1
                    continue
                key = key_elem.text or ""
                if i + 1 >= len(children):
                    break
                out[key] = decode(children[i + 1])
                i += 2
            return out
        if tag == "array":
            return [decode(child) for child in list(elem)]
        if tag == "string":
            return elem.text or ""
        if tag == "integer":
            return int(elem.text or "0")
        if tag == "real":
            return float(elem.text or "0")
        if tag == "true":
            return True
        if tag == "false":
            return False
        return elem.text or ""

    plist_dict = root.find("dict")
    data = decode(plist_dict) if plist_dict is not None else {}

    def visit(prefix: str, value):
        if isinstance(value, dict):
            for key, nested in value.items():
                visit(f"{prefix}.{key}" if prefix else key, nested)
            return
        if isinstance(value, list):
            for idx, nested in enumerate(value):
                visit(f"{prefix}[{idx}]", nested)
            return
        if not isinstance(value, str):
            return
        match = re.fullmatch(r"#([0-9A-Fa-f]{6}|[0-9A-Fa-f]{8})", value.strip())
        if not match:
            return
        raw = match.group(1)
        rgb, alpha = rgb_from_rrggbbaa(raw)
        entries.append({"token": prefix, "rgb": rgb, "alpha": alpha, "raw": f"#{raw.upper()}"})

    for idx, entry in enumerate(data.get("settings", [])):
        name = entry.get("name") or entry.get("scope") or ("global" if idx == 0 else f"entry{idx}")
        visit(name, entry.get("settings", {}))

    return entries


sources = [
    {
        "label": "Sketchybar palette",
        "variant": "tokyo-night-moon",
        "path": ROOT / "modules/home-manager/dotfiles/config/sketchybar/colors.lua",
        "parser": parse_lua_aarrggbb,
    },
    {
        "label": "Sketchybar runtime colors",
        "variant": "tokyo-night-moon",
        "path": ROOT / "modules/home-manager/dotfiles/config/sketchybar/sketchybarrc.sh",
        "parser": parse_shell_aarrggbb,
    },
    {
        "label": "Fish theme",
        "variant": "tokyo-night-moon",
        "path": ROOT / "modules/home-manager/fish/tokyo-night-moon.theme",
        "parser": parse_fish,
    },
    {
        "label": "bat theme",
        "variant": "tokyonight_night",
        "path": ROOT / "modules/home-manager/dotfiles/config/bat/themes/tokyonight_night.tmTheme",
        "parser": parse_tmtheme,
    },
]

print("Tokyo Night palette preview")
if SHOW_ALL:
    print("mode: all tokens")
elif SHOW_DETAILED:
    print("mode: grouped unique colors by source")
else:
    print("mode: unique colors")

all_grouped: OrderedDict[str, list[dict[str, str]]] = OrderedDict()
all_missing: list[dict[str, str]] = []

for source in sources:
    path = source["path"]
    if not path.exists():
        all_missing.append(source)
        continue

    entries = source["parser"](path)
    if not entries:
        continue

    if not SHOW_DETAILED and not SHOW_ALL:
        for entry in entries:
            key = entry["rgb"]
            all_grouped.setdefault(key, []).append({**entry, "source": source["label"], "variant": source["variant"], "path": str(path.relative_to(ROOT))})
        continue

    rel_path = path.relative_to(ROOT)
    print(f"\n== {source['label']} [{source['variant']}] ==")
    print(rel_path)

    if SHOW_ALL:
        print(f"{"token":<44} {"hex":<9} {"raw":<12} swatch")
        print(f"{"-" * 44} {"-" * 9} {"-" * 12} {'-' * 12}")
        for entry in entries:
            print(f"{entry['token']:<44} {entry['rgb']:<9} {entry['raw']:<12} {swatch(entry['rgb'], entry['alpha'])}")
        continue

    grouped: OrderedDict[tuple[str, str], list[str]] = OrderedDict()
    raw_by_group: dict[tuple[str, str], str] = {}
    for entry in entries:
        key = (entry["rgb"], entry["alpha"])
        grouped.setdefault(key, []).append(entry["token"])
        raw_by_group.setdefault(key, entry["raw"])

    print(f"{"hex":<9} {"raw":<12} {"count":<5} {"swatch":<12} tokens")
    print(f"{"-" * 9} {"-" * 12} {"-" * 5} {'-' * 12} {'-' * 30}")
    for (rgb, alpha), tokens in grouped.items():
        print(f"{rgb:<9} {raw_by_group[(rgb, alpha)]:<12} {len(tokens):<5} {swatch(rgb, alpha):<12} {token_preview(tokens)}")

if not SHOW_DETAILED and not SHOW_ALL:
    named = []
    family_buckets: dict[str, list[tuple[str, tuple[int, float, float, float]]]] = defaultdict(list)
    for rgb in all_grouped.keys():
        family, sort_key = family_and_sort_key(rgb)
        family_buckets[family].append((rgb, sort_key))

    for family in ["black", "gray", "white", "red", "orange", "yellow", "green", "cyan", "blue", "purple", "pink", "other"]:
        items = sorted(family_buckets.get(family, []), key=lambda item: item[1])
        for idx, (rgb, _sort_key) in enumerate(items, start=1):
            named.append((f"{family}_{idx}", rgb))

    print()
    print(f"{"name":<12} {"hex":<9} swatch")
    print(f"{"-" * 12} {"-" * 9} {'-' * 12}")
    for name, rgb in named:
        chosen = preferred_entry(all_grouped[rgb])
        print(f"{name:<12} {rgb:<9} {swatch(rgb, chosen['alpha'])}")
    if all_missing:
        print()
        print("missing sources:")
        for source in all_missing:
            print(f"- {source['label']} [{source['variant']}]")
PY
