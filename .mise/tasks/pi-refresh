#!/usr/bin/env bash
#MISE description="Force nix-managed pi package refresh for personal + work profiles"
set -euo pipefail

pi_bin="$(command -v pi)"
if [ -z "$pi_bin" ]; then
  echo "pi not found in PATH" >&2
  exit 1
fi

refresh_profile() {
  local profile_dir="$1"
  local label="$2"
  local marker="$profile_dir/packages-installed"
  local settings_file="$profile_dir/settings.json"

  echo "Refreshing $label profile: $profile_dir"

  if [ -f "$settings_file" ]; then
    while IFS= read -r package_source; do
      [ -n "$package_source" ] || continue
      rm -rf "$profile_dir/git/${package_source#git:}"
    done < <(
      python3 - "$settings_file" <<'PY'
import json
import sys
from pathlib import Path

settings = Path(sys.argv[1])
for package in json.loads(settings.read_text()).get("packages", []):
    if isinstance(package, str) and package.startswith("git:"):
        print(package)
PY
    )
  fi

  rm -f "$marker"
  PI_CODING_AGENT_DIR="$profile_dir" "$pi_bin" list >/dev/null
  echo "Refreshed $label profile"
}

refresh_profile "$HOME/.config/pi" "personal"
refresh_profile "$HOME/.config/pi-work" "work"

echo "Done"
